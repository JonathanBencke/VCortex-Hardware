  ;; ============================================================
  ;; RESUMO BOM — STAGE 1 (Power)
  ;; ============================================================
  (text "RESUMO DE COMPONENTES — STAGE 1 (Power)\n\nREF        VALUE           LCSC         FOOTPRINT       FUNCAO\nQ1         PMV45EN2R       C2976873     SOT-23          P-MOSFET protecao inversao (|VDS|=40V)\nR_GATE     10k             C25741       0402            Gate pull-down Q1\nF1         MF-MSMF300-2    C383507      1812            Polyfuse 3A/30V\nTVS1       SMDJ22A         C4154722     SMC             TVS 22V/1500W load dump\nL1         10uH/4A         C408444      SWPA6028        Indutor filtro ENTRADA Buck (NAO chaveamento)\nC1         100uF/50V       C428637      CP_Elec_8x10    Bulk entrada Buck\nC_IN       100nF/100V      C14663       0402            Decoupling VIN LMR14020\nC_BOOT     100nF           C14663       0402            Bootstrap LMR14020\nU_BUCK     LMR14020SDDAR   C187824      SOT-23-6        Buck 40V/2A 5V\nL_SW       SRR1260-4R7Y    (verificar)  Bourns_SRR1260  Indutor CHAVEAMENTO Buck 4.7uH (DIFERENTE de L1!)\nR_BOOT_BK  100k            C25741       0402            Feedback top Buck\nR_BOT_BK   18k 1%          (verificar)  0402            Feedback bot Buck -> VOUT=5V CORRIGIDO de 56.2k\nC_BOUT1    22uF/10V        C5403        1206            Saida Buck bulk 1\nC_BOUT2    22uF/10V        C5403        1206            Saida Buck bulk 2\nC_BOUT3    100nF           C14663       0402            Saida Buck bypass 100nF\nC_BOUT4    10nF            C15849       0402            Saida Buck bypass 10nF (NOVO)\nL_FILT     10uH/1A         (verificar)  SRR0604         Filtro pos-Buck -> LDO (NOVO, era ausente)\nC_FILT     10uF X5R        C96446       0805            Cap filtro L_FILT (NOVO)\nU_LDO      AP2112K-3.3     C51118       SOT-23-5        LDO 5V->3.3V 600mA\nC_LDO_IN   1uF             C52923       0402            Entrada LDO\nC_LDO_OUT  10uF            C96446       0805            Saida LDO"
    (at 20 680)
    (effects (font (size 1.5 1.5)) (justify left top))
    (uuid "11000006-0000-0000-0000-000000000001")
  )
)
