  ;; ============================================================
  ;; RESUMO BOM — STAGE 1 (Power) — CODIGOS LCSC VERIFICADOS v1.2
  ;; ============================================================
  (text "RESUMO DE COMPONENTES — STAGE 1 (Power) — rev v1.2\n\nREF        VALUE           LCSC         FOOTPRINT         FUNCAO\nQ1         PMV45EN2R-JSM   C53113978    SOT-23            P-MOSFET protecao inversao (|VDS|=40V)\nR_GATE     10k             C60490       0402              Gate pull-down Q1\nF1         MF-MSMF300/60-2 C383507      1812              Polyfuse 3A/60V (Bourns) — CORRIGIDO v1.3: era 30V\nTVS1       SMDJ22A         C4154722     SMC               TVS 22V/1500W load dump\nL1         10uH/4A         C354625      L_6.0x6.0mm       Indutor filtro ENTRADA Buck (NAO chaveamento)\nC1         100uF/50V       C3445238     CP_Elec_6.3x7.7   Bulk entrada Buck (KNSCHA D6.3x7mm)\nC_IN       100nF/100V      C14663       0402              Decoupling VIN LMR14020\nC_BOOT     100nF           C14663       0402              Bootstrap LMR14020\nU_BUCK     LMR14020SDDAR   C187824      SOT-23-6          Buck 40V/2A 5V\nL_SW       XRNR4030-4.7uH  C5289366     L_4.0x4.0mm       Indutor CHAVEAMENTO Buck 4.7uH (DIFERENTE de L1)\nR_BOOT_BK  100k 1%         C60491       0402              Feedback top Buck (YAGEO RC0402FR-07100KL)\nR_BOT_BK   18k 1%          C25762       0402              Feedback bot Buck -> VOUT=5V (UNI-ROYAL)\nC_BOUT1    22uF/10V X5R    C380338      0805              Saida Buck bulk 1 (CCTC, FOOTPRINT 1206->0805)\nC_BOUT2    22uF/10V X5R    C380338      0805              Saida Buck bulk 2\nC_BOUT3    100nF           C14663       0402              Saida Buck bypass 100nF\nC_BOUT4    10nF            C15849       0402              Saida Buck bypass 10nF\nL_FILT     10uH/1A         C135263      L_4.0x2.0mm       Filtro pos-Buck -> LDO (Shun Xiang Nuo SMNR4020)\nC_FILT     10uF X5R        C96446       0805              Cap filtro L_FILT\nU_LDO      AP2112K-3.3     C51118       SOT-23-5          LDO 5V->3.3V 600mA\nC_LDO_IN   1uF             C52923       0402              Entrada LDO\nC_LDO_OUT  10uF            C96446       0805              Saida LDO"
    (at 20 680)
    (effects (font (size 1.5 1.5)) (justify left top))
    (uuid "11000006-0000-0000-0000-000000000001")
  )
